{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/load-analysis-rules.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*__query|mcp__.*__execute_sql",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sql-safety-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bq-cost-gate.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sql-conventions-context.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*__query|mcp__.*__execute_sql",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/query-audit-log.sh\"" }
        ]
      }
    ]
  }
}
